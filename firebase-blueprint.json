{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "preferences": {
          "type": "object",
          "properties": {
            "theme": { "type": "string", "enum": ["light", "dark", "telegram"] },
            "language": { "type": "string" },
            "notificationsEnabled": { "type": "boolean" },
            "notificationSound": { "type": "string" },
            "learnedPreferences": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": { "type": "string" },
                  "category": { "type": "string", "enum": ["schedule", "communication", "interests", "general"] },
                  "content": { "type": "string" },
                  "confidence": { "type": "number" },
                  "source": { "type": "string" },
                  "updatedAt": { "type": "string", "format": "date-time" }
                }
              }
            }
          }
        }
      },
      "required": ["uid", "email"]
    },
    "Reminder": {
      "title": "Reminder",
      "description": "A reminder for the user",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "title": { "type": "string" },
        "time": { "type": "string", "format": "date-time" },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "title", "time", "completed"]
    },
    "Task": {
      "title": "Task",
      "description": "A scheduled task or event",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string" },
        "startTime": { "type": "string" },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "title", "date", "completed"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message history",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "feedback": { "type": "string", "enum": ["positive", "negative"] }
      },
      "required": ["uid", "role", "content", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/reminders/{reminderId}": {
      "schema": "Reminder",
      "description": "User reminders"
    },
    "/users/{userId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "User tasks"
    },
    "/users/{userId}/messages/{messageId}": {
      "schema": "Message",
      "description": "User chat history"
    }
  }
}
